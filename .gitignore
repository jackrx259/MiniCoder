# ── Config & Secrets ──────────────────────────────────────────────────────────
# Contains your API key — never commit this file.
# Copy config.example.json and rename it to config.json to get started.
config.json

# ── Session & User Data ───────────────────────────────────────────────────────
# Saved conversation history; may contain sensitive information.
session.json

# ── Skills (User-Created Workflows) ──────────────────────────────────────────
# Skill files are generated at runtime by the agent and are personal to each
# user's setup. They are not part of the source code.
skills/

